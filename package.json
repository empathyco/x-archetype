{
  "name": "@empathyco/x-archetype",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Starting point to setup a X Components project",
  "author": "Empathy Systems Corporation S.L.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/empathyco/x-archetype",
  "scripts": {
    "prepare": "husky install && skilld update -b",
    "serve": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "build:preview": "npm run build && npm run preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo 'Pending creation of e2e tests with Playwright.'",
    "install:x-components:local": "npm install file:$(ls ../x/packages/x-components/*.tgz | sort -V | tail 1) --no-save",
    "install:x-design-system:local": "npm install file:$(ls ../x/packages/x-design-system/*.tgz | sort -V | tail 1) --no-save",
    "install:x-adapter:local": "npm install file:$(ls ../x/packages/x-adapter/*.tgz | sort -V | tail 1) --no-save",
    "install:x-adapter-platform:local": "npm install file:$(ls ../x/packages/x-adapter-platform/*.tgz | sort -V | tail 1) --no-save",
    "install:x-types:local": "npm install file:$(ls ../x/packages/x-types/*.tgz | sort -V | tail 1) --no-save",
    "install:x-utils:local": "npm install file:$(ls ../x/packages/x-archetype-utils/*.tgz | sort -V | tail 1) --no-save",
    "install:x-archetype-utils:local": "npm install file:$(ls ../x/packages/x-archetype-utils/*.tgz | sort -V | tail 1) --no-save"
  },
  "dependencies": {
    "@empathyco/x-adapter": "8.1.6",
    "@empathyco/x-adapter-platform": "1.4.0",
    "@empathyco/x-archetype-utils": "2.0.5",
    "@empathyco/x-components": "6.3.0",
    "@empathyco/x-types": "10.3.0",
    "@empathyco/x-utils": "1.0.7",
    "@vueuse/core": "14.2.1",
    "tslib": "2.8.1",
    "vue": "3.5.33",
    "vue-i18n": "11.4.4",
    "vuex": "4.0.2"
  },
  "devDependencies": {
    "@empathyco/eslint-config": "1.10.31",
    "@empathyco/x-design-system": "1.0.6",
    "@intlify/unplugin-vue-i18n": "11.2.3",
    "@tailwindcss/vite": "4.2.4",
    "@types/dom-speech-recognition": "0.0.9",
    "@vitejs/plugin-vue": "5.2.4",
    "husky": "8.0.3",
    "lint-staged": "17.0.5",
    "rollup-plugin-visualizer": "7.0.1",
    "skilld": "2.0.0",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-css-injected-by-js": "4.0.1",
    "vue-tsc": "3.2.7"
  },
  "lint-staged": {
    "*": [
      "npm run format:check",
      "npm run lint:check"
    ]
  }
}
