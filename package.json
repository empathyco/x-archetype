{
  "name": "@empathyco/x-archetype",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Starting point to setup a X Components project",
  "author": "Empathy Systems Corporation S.L.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/empathyco/x-archetype",
  "scripts": {
    "prepare": "husky install && skilld update -b",
    "serve": "vite dev",
    "serve:docker": "VITE_APP_DEVELOPMENT_DOCKER=true npm run serve",
    "build": "vite build",
    "preview": "vite preview",
    "build:docker": "VITE_APP_DEVELOPMENT_DOCKER=true npm run build",
    "build:preview": "npm run build && npm run preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cy:open": "cypress open --e2e --browser chrome",
    "cy:run": "cypress run --env TAGS=\"not @skip\" --headless --browser chrome",
    "test:e2e": "start-server-and-test serve http://localhost:8080 cy:open",
    "test:e2e:ci": "start-server-and-test serve http://localhost:8080 cy:run",
    "test": "npm run test:e2e:ci",
    "install:x-components:local": "npm install file:$(ls ../x/packages/x-components/*.tgz | sort -V | tail 1) --no-save",
    "install:x-design-system:local": "npm install file:$(ls ../x/packages/x-design-system/*.tgz | sort -V | tail 1) --no-save",
    "install:x-adapter:local": "npm install file:$(ls ../x/packages/x-adapter/*.tgz | sort -V | tail 1) --no-save",
    "install:x-adapter-platform:local": "npm install file:$(ls ../x/packages/x-adapter-platform/*.tgz | sort -V | tail 1) --no-save",
    "install:x-types:local": "npm install file:$(ls ../x/packages/x-types/*.tgz | sort -V | tail 1) --no-save",
    "install:x-utils:local": "npm install file:$(ls ../x/packages/x-archetype-utils/*.tgz | sort -V | tail 1) --no-save",
    "install:x-archetype-utils:local": "npm install file:$(ls ../x/packages/x-archetype-utils/*.tgz | sort -V | tail 1) --no-save"
  },
  "dependencies": {
    "@empathyco/x-adapter": "8.1.4",
    "@empathyco/x-adapter-platform": "1.1.4",
    "@empathyco/x-archetype-utils": "2.0.2",
    "@empathyco/x-components": "6.0.6",
    "@empathyco/x-types": "10.1.4",
    "@empathyco/x-utils": "1.0.5",
    "@vueuse/core": "14.2.1",
    "tslib": "2.8.1",
    "vue": "3.5.33",
    "vue-i18n": "9.14.5",
    "vuex": "4.0.2"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "2.2.8",
    "@cucumber/messages": "31.2.0",
    "@empathyco/eslint-config": "1.10.31",
    "@empathyco/x-design-system": "1.0.1",
    "@tailwindcss/vite": "4.2.4",
    "@types/cypress-cucumber-preprocessor": "4.0.5",
    "@types/dom-speech-recognition": "0.0.9",
    "@vitejs/plugin-vue": "5.2.4",
    "cypress": "14.5.4",
    "husky": "8.0.3",
    "lint-staged": "15.5.2",
    "rollup-plugin-visualizer": "7.0.1",
    "skilld": "1.7.2",
    "start-server-and-test": "2.1.5",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-css-injected-by-js": "4.0.1",
    "vue-tsc": "3.2.7"
  },
  "lint-staged": {
    "*": [
      "npm run format:check",
      "npm run lint:check"
    ]
  }
}
