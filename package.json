{
  "name": "@empathyco/x-archetype",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Starting point to setup a X Components project",
  "author": "Empathy Systems Corporation S.L.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/empathyco/x-archetype",
  "scripts": {
    "serve": "vite dev",
    "serve:docker": "VITE_APP_DEVELOPMENT_DOCKER=true npm run serve",
    "serve:preview": "vite preview",
    "build": "vite build",
    "build:docker": "VITE_APP_DEVELOPMENT_DOCKER=true npm run build",
    "build:preview": "npm run build && npm run serve:preview",
    "typecheck": "vue-tsc --noEmit",
    "cy:open": "cypress open --e2e --browser chrome",
    "cy:run": "cypress run --env TAGS=\"not @skip\" --headless --browser chrome",
    "test:e2e": "start-server-and-test serve http://localhost:8080 cy:open",
    "test:e2e:ci": "start-server-and-test serve http://localhost:8080 cy:run",
    "test": "npm run test:e2e:ci",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "prepare": "husky install && skilld update -b"
  },
  "dependencies": {
    "@empathyco/x-adapter": "8.1.0-alpha.23",
    "@empathyco/x-adapter-platform": "1.1.0-alpha.64",
    "@empathyco/x-archetype-utils": "2.0.0-alpha.40",
    "@empathyco/x-components": "file://../x/packages/x-components/empathyco-x-components-6.0.0-alpha.235.tgz",
    "@empathyco/x-types": "10.1.0-alpha.53",
    "@empathyco/x-utils": "1.0.3-alpha.18",
    "@vueuse/core": "14.2.1",
    "tslib": "2.8.1",
    "vue": "3.5.30",
    "vue-i18n": "9.14.5",
    "vuex": "4.0.2"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "2.2.8",
    "@cucumber/messages": "31.2.0",
    "@empathyco/eslint-config": "1.10.31",
    "@empathyco/x-design-system": "0.1.0-alpha.2",
    "@tailwindcss/vite": "4.2.2",
    "@types/cypress-cucumber-preprocessor": "4.0.5",
    "@types/dom-speech-recognition": "0.0.7",
    "@vitejs/plugin-vue": "5.2.4",
    "cypress": "14.5.4",
    "husky": "8.0.3",
    "lint-staged": "15.5.2",
    "skilld": "1.5.5",
    "start-server-and-test": "2.1.5",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vite": "6.4.1",
    "vite-plugin-css-injected-by-js": "4.0.1",
    "vue-tsc": "3.2.6"
  },
  "lint-staged": {
    "*": [
      "npm run format:check",
      "npm run lint:check"
    ]
  }
}
